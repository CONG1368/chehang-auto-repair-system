{
  "name": "chehang-auto-repair-system",
  "version": "1.0.0",
  "private": true,
  "description": "车行综合管理系统 - 数字化管理 · 智能化运营 · 一体化服务",
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web-admin dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "build:server": "pnpm --filter server build",
    "build:web": "pnpm --filter web-admin build",
    "build:mobile": "pnpm --filter mobile build",
    "db:generate": "pnpm --filter server db:generate",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:seed": "pnpm --filter server db:seed",
    "start:prod": "pnpm --filter server start:prod",
    "db:push": "pnpm --filter server db:push",
    "db:deploy": "pnpm --filter server db:deploy",
    "test": "pnpm --filter server test",
    "test:e2e": "npx playwright test --reporter=list"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "marked": "^18.0.4",
    "playwright": "^1.60.0"
  }
}
