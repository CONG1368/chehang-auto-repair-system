generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============ 系统管理 ============

model SysUser {
  id          Int       @id @default(autoincrement())
  username    String    @unique @db.VarChar(50)
  password    String    @db.VarChar(255)
  realName    String    @map("real_name") @db.VarChar(50)
  phone       String?   @db.VarChar(20)
  email       String?   @db.VarChar(100)
  avatar      String?   @db.VarChar(255)
  roleId      Int       @map("role_id")
  status      Int       @default(1) @db.TinyInt
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  role SysRole @relation(fields: [roleId], references: [id])
  salesLeads        SalesLead[]
  repairOrders      RepairOrder[]
  dispatchRecords   DispatchRecord[]
  followRecords     FollowRecord[]
  leadFollowRecords LeadFollowRecord[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@map("sys_user")
}

model SysRole {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  code        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  permissions Json?    @db.Json
  status      Int      @default(1) @db.TinyInt
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users SysUser[]

  @@map("sys_role")
}

// ============ 客户管理 ============

model Customer {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  phone       String   @db.VarChar(20)
  gender      Int?     @db.TinyInt
  birthday    DateTime?
  address     String?  @db.VarChar(200)
  memberCardNo String? @map("member_card_no") @db.VarChar(50)
  memberLevel  Int?    @default(0) @map("member_level") @db.TinyInt
  points      Int      @default(0)
  balance     Decimal  @default(0) @db.Decimal(10, 2)
  totalSpent  Decimal  @default(0) @map("total_spent") @db.Decimal(12, 2)
  visitCount  Int      @default(0) @map("visit_count")
  lastVisitAt DateTime? @map("last_visit_at")
  tags        String?  @db.VarChar(200)
  source      String?  @db.VarChar(50)
  status      Int      @default(1) @db.TinyInt
  remark      String?  @db.VarChar(500)
  images      Json?    @map("images") @db.Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vehicles       CustomerVehicle[]
  followRecords  FollowRecord[]
  repairOrders   RepairOrder[]
  salesLeads     SalesLead[]
  salesOrders    SalesOrder[]
  paymentRecords PaymentRecord[]
  receivables    Receivable[]
  memberCardRecharges MemberCardRecharge[]
  beautyAppointments BeautyAppointment[]
  invoiceRecords   InvoiceRecord[]

  @@map("customer")
}

model CustomerVehicle {
  id           Int      @id @default(autoincrement())
  customerId   Int      @map("customer_id")
  plateNumber  String   @map("plate_number") @db.VarChar(20)
  brand        String   @db.VarChar(50)
  series       String?  @db.VarChar(50)
  model        String?  @db.VarChar(100)
  year         String?  @db.VarChar(10)
  vin          String?  @db.VarChar(50)
  engineNo     String?  @map("engine_no") @db.VarChar(50)
  color        String?  @db.VarChar(20)
  mileage      Int?     @default(0)
  purchaseDate DateTime? @map("purchase_date")
  insuranceDue DateTime? @map("insurance_due")
  inspectionDue DateTime? @map("inspection_due")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("customer_vehicle")
}

model FollowRecord {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  userId      Int      @map("user_id")
  type        String   @db.VarChar(30)
  content     String   @db.VarChar(1000)
  nextFollowAt DateTime? @map("next_follow_at")
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])
  user     SysUser  @relation(fields: [userId], references: [id])

  @@map("follow_record")
}

model MemberCard {
  id          Int      @id @default(autoincrement())
  cardNo      String   @unique @map("card_no") @db.VarChar(50)
  name        String   @db.VarChar(50)
  level       Int      @db.TinyInt
  discount    Decimal  @db.Decimal(3, 2)
  minRecharge Decimal  @default(0) @map("min_recharge") @db.Decimal(10, 2)
  status      Int      @default(1) @db.TinyInt
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("member_card")
}

model MemberCardRecharge {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  amount      Decimal  @db.Decimal(10, 2)
  paymentMethod String  @map("payment_method") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("member_card_recharge")
}

// ============ 库存管理 ============

model PartCategory {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  parentId  Int?     @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  parts Part[]

  @@map("part_category")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  contact   String?  @db.VarChar(50)
  phone     String?  @db.VarChar(20)
  address   String?  @db.VarChar(200)
  bankAccount String? @map("bank_account") @db.VarChar(50)
  status    Int      @default(1) @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at")

  parts         Part[]
  purchaseOrders PurchaseOrder[]
  payables      Payable[]

  @@map("supplier")
}

model Part {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(50)
  name          String   @db.VarChar(100)
  spec          String?  @db.VarChar(50)
  unit          String   @default("个") @db.VarChar(10)
  categoryId    Int      @map("category_id")
  supplierId    Int?     @map("supplier_id")
  price         Decimal  @db.Decimal(10, 2)
  cost          Decimal  @db.Decimal(10, 2)
  safetyStock   Int      @default(10) @map("safety_stock") @db.Int
  maxStock      Int      @default(100) @map("max_stock") @db.Int
  shelfLocation String?  @map("shelf_location") @db.VarChar(50)
  images        Json?    @map("images") @db.Json
  status        Int      @default(1) @db.TinyInt
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category  PartCategory @relation(fields: [categoryId], references: [id])
  supplier  Supplier?    @relation(fields: [supplierId], references: [id])
  stock            PartStock?
  stockRecords     StockRecord[]
  purchaseItems    PurchaseOrderItem[]

  @@map("part")
}

model PartStock {
  id        Int      @id @default(autoincrement())
  partId    Int      @unique @map("part_id")
  warehouse String   @default("默认仓库") @db.VarChar(50)
  quantity  Int      @default(0)
  lockedQty Int      @default(0) @map("locked_qty")
  updatedAt DateTime @updatedAt @map("updated_at")

  part Part @relation(fields: [partId], references: [id])

  @@map("part_stock")
}

model StockRecord {
  id          Int      @id @default(autoincrement())
  partId      Int      @map("part_id")
  type        String   @db.VarChar(20)
  quantity    Int
  beforeQty   Int      @map("before_qty")
  afterQty    Int      @map("after_qty")
  relatedNo   String?  @map("related_no") @db.VarChar(50)
  operator    String?  @db.VarChar(50)
  remark      String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")

  part Part @relation(fields: [partId], references: [id])

  @@map("stock_record")
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique @map("order_no") @db.VarChar(50)
  supplierId  Int      @map("supplier_id")
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(10, 2)
  status      String   @default("pending") @db.VarChar(20)
  applicantId Int      @map("applicant_id")
  attachments Json?    @map("attachments") @db.Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  supplier    Supplier @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]

  @@map("purchase_order")
}

model PurchaseOrderItem {
  id             Int     @id @default(autoincrement())
  purchaseOrderId Int    @map("purchase_order_id")
  partId         Int     @map("part_id")
  quantity       Int
  unitPrice      Decimal @map("unit_price") @db.Decimal(10, 2)
  amount         Decimal @db.Decimal(10, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  part           Part          @relation(fields: [partId], references: [id])

  @@map("purchase_order_item")
}

// ============ 维修服务 ============

model RepairOrder {
  id              Int       @id @default(autoincrement())
  orderNo         String    @unique @map("order_no") @db.VarChar(50)
  customerId      Int       @map("customer_id")
  vehicleId       Int?      @map("vehicle_id")
  plateNumber     String    @map("plate_number") @db.VarChar(20)
  vehicleModel    String?   @map("vehicle_model") @db.VarChar(100)
  mileage         Int?
  status          String    @default("pending") @db.VarChar(20)
  faultDesc       String?   @map("fault_desc") @db.VarChar(1000)
  checkResult     String?   @map("check_result") @db.VarChar(500)
  totalLaborFee   Decimal   @default(0) @map("total_labor_fee") @db.Decimal(10, 2)
  totalPartFee    Decimal   @default(0) @map("total_part_fee") @db.Decimal(10, 2)
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(10, 2)
  discount        Decimal   @default(0) @db.Decimal(10, 2)
  finalAmount     Decimal   @default(0) @map("final_amount") @db.Decimal(10, 2)
  advisorId       Int       @map("advisor_id")
  estCompleteTime DateTime? @map("est_complete_time")
  actualCompleteTime DateTime? @map("actual_complete_time")
  deliveryMethod  String?   @map("delivery_method") @db.VarChar(20)
  images          Json?     @map("images") @db.Json
  checkImages     Json?     @map("check_images") @db.Json
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  customer       Customer           @relation(fields: [customerId], references: [id])
  advisor        SysUser            @relation(fields: [advisorId], references: [id])
  items          RepairOrderItem[]
  dispatchRecords DispatchRecord[]
  qualityCheck   QualityCheck?
  paymentRecords PaymentRecord[]

  @@map("repair_order")
}

model RepairOrderItem {
  id          Int      @id @default(autoincrement())
  repairOrderId Int    @map("repair_order_id")
  type        String   @db.VarChar(20)
  name        String   @db.VarChar(100)
  laborFee    Decimal  @default(0) @map("labor_fee") @db.Decimal(10, 2)
  partFee     Decimal  @default(0) @map("part_fee") @db.Decimal(10, 2)
  amount      Decimal  @default(0) @db.Decimal(10, 2)
  status      String   @default("pending") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@map("repair_order_item")
}

model DispatchRecord {
  id            Int      @id @default(autoincrement())
  repairOrderId Int      @map("repair_order_id")
  technicianId  Int      @map("technician_id")
  standardHours Decimal? @map("standard_hours") @db.Decimal(5, 1)
  actualHours   Decimal? @map("actual_hours") @db.Decimal(5, 1)
  status        String   @default("assigned") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])
  technician  SysUser     @relation(fields: [technicianId], references: [id])

  @@map("dispatch_record")
}

model QualityCheck {
  id            Int      @id @default(autoincrement())
  repairOrderId Int      @unique @map("repair_order_id")
  checkerId     Int      @map("checker_id")
  itemsChecked  Json?    @map("items_checked") @db.Json
  roadTest      String?  @map("road_test") @db.VarChar(20)
  isPassed      Int      @default(1) @map("is_passed") @db.TinyInt
  remark        String?  @db.VarChar(500)
  createdAt     DateTime @default(now()) @map("created_at")

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id])

  @@map("quality_check")
}

// ============ 新车销售 ============

model VehicleInfo {
  id           Int      @id @default(autoincrement())
  brand        String   @db.VarChar(50)
  series       String   @db.VarChar(50)
  model        String   @db.VarChar(100)
  yearModel    String?  @map("year_model") @db.VarChar(10)
  config       String?  @db.VarChar(200)
  color        String?  @db.VarChar(50)
  vin          String?  @unique @db.VarChar(50)
  guidePrice   Decimal  @map("guide_price") @db.Decimal(12, 2)
  salePrice    Decimal  @map("sale_price") @db.Decimal(12, 2)
  minPrice     Decimal  @map("min_price") @db.Decimal(12, 2)
  stockStatus  String   @default("in_stock") @map("stock_status") @db.VarChar(20)
  location     String?  @db.VarChar(100)
  images       Json?    @map("images") @db.Json
  status       Int      @default(1) @db.TinyInt
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  salesOrders SalesOrder[]

  @@map("vehicle_info")
}

model SalesLead {
  id          Int      @id @default(autoincrement())
  customerId  Int?     @map("customer_id")
  userId      Int      @map("user_id")
  source      String?  @db.VarChar(50)
  intent      String?  @db.VarChar(20)
  intentModel String?  @map("intent_model") @db.VarChar(100)
  budget      Decimal? @db.Decimal(12, 2)
  status      String   @default("new") @db.VarChar(20)
  nextFollowAt DateTime? @map("next_follow_at")
  remark      String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer      Customer?          @relation(fields: [customerId], references: [id])
  user          SysUser            @relation(fields: [userId], references: [id])
  followRecords LeadFollowRecord[]

  @@map("sales_lead")
}

model LeadFollowRecord {
  id          Int      @id @default(autoincrement())
  leadId      Int      @map("lead_id")
  userId      Int      @map("user_id")
  type        String   @db.VarChar(30)
  content     String   @db.VarChar(1000)
  nextFollowAt DateTime? @map("next_follow_at")
  createdAt   DateTime @default(now()) @map("created_at")

  lead SalesLead @relation(fields: [leadId], references: [id])
  user SysUser   @relation(fields: [userId], references: [id])

  @@map("lead_follow_record")
}

model SalesOrder {
  id           Int      @id @default(autoincrement())
  orderNo      String   @unique @map("order_no") @db.VarChar(50)
  customerId   Int      @map("customer_id")
  vehicleId    Int      @map("vehicle_id")
  salePrice    Decimal  @map("sale_price") @db.Decimal(12, 2)
  discount     Decimal  @default(0) @db.Decimal(10, 2)
  tax          Decimal  @default(0) @db.Decimal(10, 2)
  insurance    Decimal  @default(0) @db.Decimal(10, 2)
  accessories  Decimal  @default(0) @db.Decimal(10, 2)
  serviceFee   Decimal  @default(0) @map("service_fee") @db.Decimal(10, 2)
  deposit      Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount  Decimal  @map("total_amount") @db.Decimal(12, 2)
  paymentMethod String? @map("payment_method") @db.VarChar(20)
  status       String   @default("pending") @db.VarChar(20)
  deliveryDate DateTime? @map("delivery_date")
  deliveryChecklist Json? @map("delivery_checklist")
  deliveryRemark String? @map("delivery_remark") @db.VarChar(500)
  salesId      Int      @map("sales_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer Customer     @relation(fields: [customerId], references: [id])
  vehicle  VehicleInfo  @relation(fields: [vehicleId], references: [id])

  @@map("sales_order")
}

// ============ 美容服务 ============

model BeautyService {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  category  String   @db.VarChar(30)
  price     Decimal  @db.Decimal(10, 2)
  duration  Int?
  status    Int      @default(1) @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at")

  @@map("beauty_service")
}

model BeautyPackage {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  originalPrice Decimal  @map("original_price") @db.Decimal(10, 2)
  packagePrice  Decimal  @map("package_price") @db.Decimal(10, 2)
  items         Json?    @db.Json
  status        Int      @default(1) @db.TinyInt
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("beauty_package")
}

model BeautyAppointment {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  vehicleId   Int?     @map("vehicle_id")
  serviceType String   @map("service_type") @db.VarChar(30)
  items       Json?    @db.Json
  totalAmount Decimal  @default(0) @map("total_amount") @db.Decimal(10, 2)
  status      String   @default("pending") @db.VarChar(20)
  assignedTo  Int?     @map("assigned_to")
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("beauty_appointment")
}

// ============ 财务管理 ============

model PaymentRecord {
  id            Int      @id @default(autoincrement())
  paymentNo     String   @unique @map("payment_no") @db.VarChar(50)
  customerId    Int      @map("customer_id")
  repairOrderId Int?     @map("repair_order_id")
  salesOrderId  Int?     @map("sales_order_id")
  type          String   @db.VarChar(20)
  amount        Decimal  @db.Decimal(10, 2)
  paymentMethod String   @map("payment_method") @db.VarChar(20)
  discount      Decimal  @default(0) @db.Decimal(10, 2)
  status        String   @default("completed") @db.VarChar(20)
  operatorId    Int      @map("operator_id")
  remark        String?  @db.VarChar(200)
  createdAt     DateTime @default(now()) @map("created_at")

  customer    Customer     @relation(fields: [customerId], references: [id])
  repairOrder RepairOrder? @relation(fields: [repairOrderId], references: [id])

  @@map("payment_record")
}

model Receivable {
  id          Int      @id @default(autoincrement())
  customerId  Int      @map("customer_id")
  amount      Decimal  @db.Decimal(10, 2)
  paidAmount  Decimal  @default(0) @map("paid_amount") @db.Decimal(10, 2)
  dueDate     DateTime? @map("due_date")
  status      String   @default("pending") @db.VarChar(20)
  source      String   @db.VarChar(30)
  sourceNo    String   @map("source_no") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("receivable")
}

model Payable {
  id          Int      @id @default(autoincrement())
  supplierId  Int      @map("supplier_id")
  amount      Decimal  @db.Decimal(10, 2)
  paidAmount  Decimal  @default(0) @map("paid_amount") @db.Decimal(10, 2)
  dueDate     DateTime? @map("due_date")
  status      String   @default("pending") @db.VarChar(20)
  source      String   @db.VarChar(30)
  sourceNo    String   @map("source_no") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("payable")
}

model ExpenseRecord {
  id          Int      @id @default(autoincrement())
  category    String   @db.VarChar(30)
  amount      Decimal  @db.Decimal(10, 2)
  description String?  @db.VarChar(200)
  operatorId  Int      @map("operator_id")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("expense_record")
}

// ============ 发票管理 ============

model InvoiceRecord {
  id         Int      @id @default(autoincrement())
  invoiceNo  String   @unique @map("invoice_no") @db.VarChar(50)
  type       String   @db.VarChar(20)
  amount     Decimal  @db.Decimal(10, 2)
  customerId Int      @map("customer_id")
  relatedNo  String   @map("related_no") @db.VarChar(50)
  status     String   @default("issued") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("invoice_record")
}

// ============ 消息通知 ============

model Notification {
  id         Int       @id @default(autoincrement())
  userId     Int?      @map("user_id")
  type       String    @default("system") @db.VarChar(20)
  title      String    @db.VarChar(200)
  content    String    @db.Text
  targetType String?   @map("target_type") @db.VarChar(30)
  targetId   Int?      @map("target_id")
  isRead     Boolean   @default(false) @map("is_read")
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user SysUser? @relation(fields: [userId], references: [id])

  @@map("notification")
  @@index([userId, isRead])
}

// ============ 系统配置 ============

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_config")
}

// ============ 操作审计 ============

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  action     String   @db.VarChar(50)
  module     String   @db.VarChar(30)
  targetId   Int?     @map("target_id")
  targetName String?  @map("target_name") @db.VarChar(100)
  detail     String?  @db.Text
  ip         String?  @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")

  user SysUser @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
