# 车行 — 生产环境变量模板（v2.0）
# 部署时复制为服务器 .env，勿提交真实密码到 Git

NODE_ENV=production
APP_NAME=车行综合管理系统
APP_PORT=3000

# 阿里云 RDS MySQL（使用内网地址）
DATABASE_URL=mysql://db_user:db_password@rm-xxxxxxxx.mysql.rds.aliyuncs.com:3306/chehang_auto?charset=utf8mb4

# JWT 密钥 — 生产必须替换为随机长字符串（建议 ≥ 32 字符）
# 使用 openssl rand -hex 32 生成
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d

# CORS 允许的域名 — 多个用英文逗号分隔（v2.0 已支持）
CORS_ORIGINS=https://admin.example.com

# Redis（建议安装：sudo apt-get install -y redis-server）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password  # 若 Redis 设置了密码，取消注释并填写

# 可选：上传文件根目录（绝对路径，默认使用 dist 同级的 uploads）
# UPLOAD_ROOT=/opt/chehang-auto/uploads
